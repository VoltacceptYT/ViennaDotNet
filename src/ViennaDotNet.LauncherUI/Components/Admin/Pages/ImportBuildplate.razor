@page "/Admin/ImportBuildplate"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = Permissions.ManageBuildplates)]
@rendermode InteractiveServer
@inject NavigationManager NavManager

<PageTitle>Import Buildplate(s)</PageTitle>

<PageTitle>Import Buildplate(s)</PageTitle>

<div class="import-container">
    <h2>Import Buildplate</h2>
    <p>Upload your buildplate configurations here.</p>

    <div class="drop-zone @(isHovering ? "hovering" : "")" 
         @ondragenter="@(() => isHovering = true)" 
         @ondragleave="@(() => isHovering = false)"
         @ondrop="@(() => isHovering = false)">
        
        <InputFile OnChange="HandleFileSelection" 
                   multiple 
                   accept=".zip,.json" 
                   class="file-input" 
                   disabled="@isUploading" />
        
        <div class="drop-zone-content">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="upload-icon" viewBox="0 0 16 16">
                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
            </svg>
            <p><strong>Drag and drop</strong> your files here, or <strong>click to browse</strong></p>
            <p class="file-hint">Accepts .zip (Vienna) or .json (Project Earth)</p>
        </div>
    </div>

    @if (selectedFiles.Any())
    {
        <div class="file-list">
            @foreach (var file in selectedFiles)
            {
                <div class="file-item">
                    <div class="file-header">
                        <span class="file-name">@file.File.Name</span>
                        <button class="btn-remove" @onclick="() => RemoveFile(file)" disabled="@file.IsComplete" title="Remove file">
                            ✕
                        </button>
                    </div>

                    @if (file.HasError)
                    {
                        <span class="text-danger file-status">@file.ErrorMessage</span>
                    }
                    else if (file.IsComplete)
                    {
                        <span class="text-success file-status">Upload Complete</span>
                    }
                    else
                    {
                        <div class="progress-bar-container">
                            <div class="progress-bar" style="width: @(file.ProgressPercentage)%"></div>
                        </div>
                        <span class="file-status">@(Math.Round(file.ProgressPercentage))%</span>
                    }
                </div>
            }
        </div>

        <button class="btn btn-primary import-btn" 
                @onclick="ProcessUploads" 
                disabled="@(isUploading || !selectedFiles.Any(f => !f.IsComplete && !f.HasError))">
            @(isUploading ? "Importing..." : "Import Buildplates")
        </button>
    }
</div>

@if (showDialog)
{
    <div class="dialog-overlay">
        <div class="dialog-card">
            <h3 class="@(isSuccess ? "text-success" : "text-danger")">
                @(isSuccess ? "Success" : "Finished with Errors")
            </h3>
            <p>@dialogMessage</p>
            <button class="btn @(isSuccess ? "btn-primary" : "btn-secondary")" @onclick="CloseDialog">
                @(isSuccess ? "Continue to Buildplates" : "Close")
            </button>
        </div>
    </div>
}

<style>
    .file-input {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        opacity: 0;
        cursor: pointer;
        z-index: 10;
    }
    
    .file-input:disabled { cursor: not-allowed; }

</style>

@code {
    private bool isHovering;
    private bool isUploading;
    private bool showDialog;
    private bool isSuccess;
    private string dialogMessage = string.Empty;

    private const long MaxFileSize = 1024 * 1024 * 100; // 100MB

    private List<FileUploadState> selectedFiles = new();

    private class FileUploadState
    {
        public IBrowserFile File { get; set; } = default!;
        public long UploadedBytes { get; set; }
        public double ProgressPercentage => File.Size == 0 ? 0 : ((double)UploadedBytes / File.Size) * 100;
        public bool IsComplete { get; set; }
        public bool HasError { get; set; }
        public string ErrorMessage { get; set; } = string.Empty;
        public CancellationTokenSource Cts { get; set; } = new();
    }

    private void HandleFileSelection(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            if (ext != ".zip" && ext != ".json")
            {
                selectedFiles.Add(new FileUploadState 
                { 
                    File = file, 
                    HasError = true, 
                    ErrorMessage = "Invalid format. Requires .zip or .json" 
                });
                continue;
            }

            if (!selectedFiles.Any(f => f.File.Name == file.Name))
            {
                selectedFiles.Add(new FileUploadState { File = file });
            }
        }
    }

    private void RemoveFile(FileUploadState fileState)
    {
        if (isUploading && !fileState.IsComplete && !fileState.HasError)
        {
            fileState.Cts.Cancel();
        }
        
        selectedFiles.Remove(fileState);
    }

    private async Task ProcessUploads()
    {
        isUploading = true;
        StateHasChanged();

        var filesToUpload = selectedFiles.Where(f => !f.IsComplete && !f.HasError).ToList();
        int successCount = 0;

        foreach (var fileState in filesToUpload)
        {
            try
            {
                await using var stream = fileState.File.OpenReadStream(MaxFileSize, fileState.Cts.Token);
                
                var buffer = new byte[512 * 1024]; // 512KB chunks
                int bytesRead;

                while ((bytesRead = await stream.ReadAsync(buffer, fileState.Cts.Token)) != 0)
                {
                    fileState.UploadedBytes += bytesRead;
                    
                    StateHasChanged(); 
                }

                fileState.IsComplete = true;
                successCount++;
            }
            catch (OperationCanceledException)
            {
                fileState.HasError = true;
                fileState.ErrorMessage = "Upload cancelled.";
            }
            catch (Exception ex)
            {
                fileState.HasError = true;
                fileState.ErrorMessage = $"Failed: {ex.Message}";
            }
            finally
            {
                StateHasChanged();
            }
        }

        isUploading = false;

        int totalAttempted = filesToUpload.Count;
        if (successCount == totalAttempted && totalAttempted > 0)
        {
            ShowDialog(true, $"Successfully imported {successCount} buildplate(s).");
        }
        else if (totalAttempted > 0)
        {
            ShowDialog(false, $"Finished. {successCount} succeeded, {totalAttempted - successCount} failed or were cancelled.");
        }
    }

    private void ShowDialog(bool success, string message)
    {
        isSuccess = success;
        dialogMessage = message;
        showDialog = true;
    }

    private void CloseDialog()
    {
        showDialog = false;
        if (isSuccess)
        {
            NavManager.NavigateTo("/Buildplates");
        }
    }
}