@page "/Admin/Roles"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using ViennaDotNet.LauncherUI.Data
@attribute [Authorize(Policy = Permissions.ManageRoles)]
@rendermode InteractiveServer
@inject RoleManager<ApplicationRole> RoleManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext DbContext

<PageTitle>Role Management</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Role Hierarchy</h2>
        <button class="btn btn-primary" @onclick="PrepareCreate">Create New Role</button>
    </div>

    @if (_roles == null)
    {
        <p><em>Loading roles...</em></p>
    }
    else
    {
        <div class="d-none d-md-block">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Position</th>
                            <th>Color</th>
                            <th>Name</th>
                            <th>Permissions</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in _roles.OrderBy(r => r.Position))
                        {
                            var canManage = role.Position > _userMinPosition && !role.IsBuiltIn;
                            <tr style="border-left: 5px solid @role.Color">
                                <td>@role.Position</td>
                                <td>
                                    <div style="width: 20px; height: 20px; background:@role.Color; border-radius: 4px;"></div>
                                </td>
                                <td>
                                    <strong>@role.Name</strong>
                                    @if (role.IsBuiltIn)
                                    {
                                        <span class="badge bg-secondary ms-2">System</span>
                                    }
                                </td>
                                <td>
                                    @RenderPermissions(role)
                                </td>
                                <td>
                                    @RenderActions((role, canManage))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-md-none">
            @foreach (var role in _roles.OrderBy(r => r.Position))
            {
                var canManage = role.Position > _userMinPosition && !role.IsBuiltIn;

                <div class="card mb-3 shadow-sm border-0" style="border-left: 5px solid @role.Color">
                    <div class="card-body">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@role.Name</strong>
                                @if (role.IsBuiltIn)
                                {
                                    <span class="badge bg-secondary ms-2">System</span>
                                }
                            </div>
                            <span class="badge bg-light text-dark">
                                #@role.Position
                            </span>
                        </div>

                        <!-- Color -->
                        <div class="mt-2 d-flex align-items-center gap-2">
                            <div style="width:16px;height:16px;background:@role.Color;border-radius:3px;"></div>
                            <small class="text-muted">@role.Color</small>
                        </div>

                        <!-- Permissions -->
                        <div class="mt-2">
                            @RenderPermissions(role)
                        </div>

                        <!-- Actions -->
                        <div class="mt-3 d-flex flex-wrap gap-2">
                            @RenderActions((role, canManage))
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_isEditing)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(_model.IsReadOnly ? "View Role Details" : (_model.Id == null ? "Create Role" : "Edit Role"))
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => _isEditing = false"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>@_errorMessage</div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Role Name</label>
                        <input class="form-control" @bind="_model.Name" disabled="@(_model.IsReadOnly)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role Color</label>
                        <input type="color" class="form-control form-control-color" @bind="_model.Color"
                               disabled="@_model.IsReadOnly" />
                    </div>

                    <h6>Permissions</h6>
                    <div class="row">
                        @foreach (var perm in Permissions.All)
                        {
                            var isAssigned = _modelPermissions.Contains(perm);
                            <div class="col-md-4">
                                <div class="form-check p-2 border rounded @(isAssigned ? "bg-light" : "")"
                                     style="cursor: pointer;">
                                    <input class="form-check-input ms-1" type="checkbox" checked="@isAssigned"
                                           disabled="@_model.IsReadOnly" @onchange="@(e => TogglePermission(perm, e.Value))" />
                                    <label class="form-check-label ms-2 @(isAssigned ? "fw-bold" : "text-muted")">
                                        @perm
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" @onclick="() => _isEditing = false">Close</button>
                    @if (!_model.IsReadOnly)
                    {
                        <button class="btn btn-primary" @onclick="SaveRole">Save Changes</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {

    private List<ApplicationRole> _roles = new();
    private int _userMinPosition = -1;
    private bool _isEditing = false;
    private RoleEditModel _model = new();
    private HashSet<string> _modelPermissions = new();
    private Dictionary<string, List<string>> _rolePermissions = new();

    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // Get the roles of the current user to find their highest position
        var userRoleNames = user.FindAll(ClaimTypes.Role).Select(c => c.Value);
        var allRoles = await RoleManager.Roles.ToListAsync();

        _userMinPosition = allRoles
            .Where(r => userRoleNames.Contains(r.Name))
            .Select(r => r.Position)
            .DefaultIfEmpty(9999) // nobody gonna have 9999 roles fr
            .Min();

        _roles = allRoles;

        _rolePermissions.Clear();
        foreach (var role in _roles)
        {
            var claims = await RoleManager.GetClaimsAsync(role);
            _rolePermissions[role.Id] = claims
                .Where(c => c.Type == "Permission")
                .Select(c => c.Value)
                .OrderBy(v => v) // Keep it alphabetical for a consistent UI
                .ToList();
        }
    }

    private void PrepareCreate()
    {
        _model = new RoleEditModel { Color = "#99AAB5", Position = RoleManager.Roles.Count(), };
        _modelPermissions.Clear();
        _isEditing = true;
    }

    private async Task EditRole(ApplicationRole role)
    {
        _errorMessage = null;

        var canEdit = role.Position > _userMinPosition && !role.IsBuiltIn;

        _model = new RoleEditModel
        {
            Id = role.Id,
            Name = role.Name,
            Color = role.Color,
            Position = role.Position,
            IsReadOnly = !canEdit,
        };

        var claims = await RoleManager.GetClaimsAsync(role);
        _modelPermissions = claims
            .Where(c => c.Type == "Permission")
            .Select(c => c.Value)
            .ToHashSet();

        _isEditing = true;
    }

    private async Task SaveRole()
    {
        _errorMessage = null; // Reset error

        ApplicationRole role;
        if (_model.Id is null)
        {
            role = new ApplicationRole
            {
                Name = string.IsNullOrWhiteSpace(_model.Name) ? "role" : _model.Name,
                Color = _model.Color,
                Position = _model.Position
            };
        }
        else
        {
            role = await RoleManager.FindByIdAsync(_model.Id);
            if (!string.IsNullOrWhiteSpace(_model.Name))
            {
                role.Name = _model.Name;
            }
            role.Color = _model.Color;
        }

        var roleName = string.IsNullOrWhiteSpace(_model.Name)
            ? (_model.Id is null ? "new-role" : role.Name)
            : _model.Name.Trim();

        var existingRole = await RoleManager.FindByNameAsync(roleName);
        if (existingRole != null && existingRole.Id != _model.Id)
        {
            _errorMessage = $"A role with the name '{roleName}' already exists.";
            return;
        }

        if (_model.Id is null)
        {
            await RoleManager.CreateAsync(role);
        }
        else
        {
            await RoleManager.UpdateAsync(role);
        }

        // Sync Permissions
        var currentClaims = await RoleManager.GetClaimsAsync(role);
        foreach (var claim in currentClaims.Where(c => c.Type == "Permission"))
        {
            await RoleManager.RemoveClaimAsync(role, claim);
        }
        foreach (var perm in _modelPermissions)
        {
            await RoleManager.AddClaimAsync(role, new Claim("Permission", perm));
        }

        _isEditing = false;
        await LoadData();
    }

    private async Task MoveUp(ApplicationRole role)
    {
        if (role.Position <= 0 || role.Position <= _userMinPosition + 1 || role.IsBuiltIn)
        {
            return;
        }

        var neighbor = _roles.First(item => item.Position == role.Position - 1);

        await SwapPositions(role, neighbor);
    }

    private async Task MoveDown(ApplicationRole role)
    {
        if (role.Position >= _roles.Count - 1 || role.Position <= _userMinPosition || role.IsBuiltIn)
        {
            return;
        }

        var neighbor = _roles.First(item => item.Position == role.Position + 1);

        await SwapPositions(role, neighbor);
    }

    private async Task SwapPositions(ApplicationRole roleA, ApplicationRole roleB)
    {
        int originalA = roleA.Position;
        int originalB = roleB.Position;

        roleA.Position = 10000;
        await RoleManager.UpdateAsync(roleA);

        roleB.Position = originalA;
        await RoleManager.UpdateAsync(roleB);

        roleA.Position = originalB;
        await RoleManager.UpdateAsync(roleA);

        await LoadData();
    }

    private async Task DeleteRole(ApplicationRole role)
    {
        if (role.Position <= _userMinPosition || role.IsBuiltIn)
        {
            return;
        }

        var rolesToShift = _roles
            .Where(r => r.Position > role.Position)
            .OrderBy(r => r.Position)
            .ToList();

        var result = await RoleManager.DeleteAsync(role);

        if (result.Succeeded)
        {
            foreach (var r in rolesToShift)
            {
                r.Position--;
                await RoleManager.UpdateAsync(r);
            }
        }

        await LoadData();
    }

    private void TogglePermission(string perm, object checkedValue)
    {
        if ((bool)checkedValue) _modelPermissions.Add(perm);
        else _modelPermissions.Remove(perm);
    }

    private string GetPermissionPreview(string roleId)
    {
        if (!_rolePermissions.TryGetValue(roleId, out var perms) || !perms.Any())
        {
            return "None";
        }

        const int MaxVisible = 3;
        var visible = perms.Take(MaxVisible);
        var summary = string.Join(", ", visible);

        if (perms.Count > MaxVisible)
        {
            summary += $" +{perms.Count - MaxVisible} more";
        }

        return summary;
    }

    RenderFragment<ApplicationRole> RenderPermissions => role => __builder =>
    {
        @if (_rolePermissions.TryGetValue(role.Id, out var perms) && perms.Any())
        {
            <div class="d-flex flex-wrap gap-1 align-items-center">
                @foreach (var p in perms.Take(3))
                {
                    <span class="badge border text-dark fw-normal" style="background-color: #f8f9fa; border-color: #dee2e6 !important;">
                        @p
                    </span>
                }
                @if (perms.Count > 3)
                {
                    <span class="badge bg-secondary-subtle text-secondary border">
                        +@(perms.Count - 3) more
                    </span>
                }
            </div>
        }
        else
        {
            <span class="text-muted small"><em>No permissions</em></span>
        }
    };

    RenderFragment<(ApplicationRole, bool)> RenderActions => item => __builder =>
    {
        var (role, canManage) = item;

        <button class="btn btn-sm @(canManage ? "btn-outline-primary" : "btn-outline-secondary")"
                @onclick="() => EditRole(role)">
            <i class="bi @(canManage ? "bi-pencil" : "bi-eye")"></i>
            @(canManage ? "Edit" : "View")
        </button>

        @if (canManage)
        {
            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRole(role)">Delete</button>
            if (role.Position > 0 && role.Position > _userMinPosition + 1)
            {
                <button class="btn btn-sm btn-light" @onclick="() => MoveUp(role)">▲</button>
            }

            if (role.Position < _roles.Count - 1)
            {
                <button class="btn btn-sm btn-light" @onclick="() => MoveDown(role)">▼</button>
            }
        }
    };

    public class RoleEditModel
    {
        public string? Id { get; set; }

        public string Name { get; set; } = "";

        public string Color { get; set; } = "#99AAB5";

        public int Position { get; set; }

        public bool IsReadOnly { get; set; }
    }
}