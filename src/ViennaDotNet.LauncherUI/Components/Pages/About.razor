@page "/About"

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            
            <h1 class="display-4 fw-bold mb-3">ViennaDotNet</h1>
            <p class="lead mb-4">
                A replacement server software for <strong>Minecraft Earth™</strong>.
            </p>

            <hr class="my-5" />

            <div class="card shadow-sm mb-5">
                <div class="card-body p-4">
                    <h3 class="h5 mb-3">Project Origins</h3>
                    <p class="text-muted">
                        Based on the original <a href="https://github.com/Project-Genoa/Vienna" target="_blank"
                                                 class="text-decoration-none">Vienna</a> project.
                    </p>
                    <p>
                        Developed by <a href="https://github.com/BitcoderCZ" target="_blank"
                                        class="fw-bold text-primary">Bitcoder</a>.
                    </p>
                    
                    <div class="mt-4">
                        <a href="https://github.com/Earth-Restored/ViennaDotNet/issues/new/choose" target="_blank"
                               class="btn btn-outline-danger">
                            <i class="bi bi-bug-fill me-2"></i>Report Bug / Request Feature
                        </a>
                    </div>
                </div>
            </div>

            <div class="alert alert-secondary small text-start shadow-sm" role="alert">
                <h4 class="alert-heading h6 fw-bold">Legal Disclaimer</h4>
                <p class="mb-0">
                    ViennaDotNet is an independent, community-driven project and is <strong>not affiliated with,
